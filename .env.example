# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Plaid (sandbox first: https://dashboard.plaid.com/developers/keys)
NEXT_PUBLIC_PLAID_ENV=sandbox
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret-sandbox

# Encryption for Plaid access tokens (min 32 chars, base64 or random hex)
PLAID_TOKEN_ENCRYPTION_KEY=your-32-char-or-longer-secret-key-here

# Optional: Webhook secret for Plaid (production)
# PLAID_WEBHOOK_SECRET=whsec_...

# Freemium: set to true to gate advanced AI scans behind paywall
NEXT_PUBLIC_FREEMIUM_ENABLED=true

# Stripe (Phase 3 — MON-1201)
# Get from Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
# Get from Stripe Dashboard → Developers → Webhooks → Add endpoint
STRIPE_WEBHOOK_SECRET=whsec_...
# Create products/prices at Stripe Dashboard → Products
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...

# Mongoori Rides internal webhook secret (shared secret)
MONGOORI_RIDES_WEBHOOK_SECRET=your-internal-secret-here

# Site URL (for Stripe redirect URLs)
NEXT_PUBLIC_SITE_URL=https://tax.mongoori.com

# Resend email (for expiry notifications — Phase 3)
# RESEND_API_KEY=re_...

# Cron secret (for /api/cron/* endpoints)
# CRON_SECRET=your-cron-secret-here

# Sentry 에러 트래킹 (MON-615)
# 계정 생성: https://sentry.io → 조직 'mongoori' → 프로젝트 'mongoori' → DSN 복사
# SDK 설치: npx @sentry/wizard@latest -i nextjs
# NEXT_PUBLIC_SENTRY_DSN=
